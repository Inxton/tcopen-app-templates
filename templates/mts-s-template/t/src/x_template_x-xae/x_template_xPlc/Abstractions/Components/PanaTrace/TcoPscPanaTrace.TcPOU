      </Get>
    </Property>
    <Method Name="InvokeConfirmSerial" Id="{48c1b220-4e0b-4efd-88b3-980db67847ed}" FolderPath="Public\">
      <Declaration><![CDATA[METHOD InvokeConfirmSerial : TcoCore.ITcoTaskStatus
VAR_INPUT
	inSerialNo : STRING;
	inRfid : STRING;
	inReference : STRING;
END_VAR
	]]></Declaration>
      <Implementation>
        <ST><![CDATA[_control.PartSerialNo := inSerialNo;
_control.Rfid := inRfid;
_control.ReferenceId := inReference;


InvokeConfirmSerial := _confirmSerialNoTask.Invoke();]]></ST>
      </Implementation>
    </Method>
    <Method Name="InvokeGenerateSerialNo" Id="{cf4b5f21-f16e-49ae-8f08-78db3fcecc95}" FolderPath="Public\">
      <Declaration><![CDATA[METHOD InvokeGenerateSerialNo : TcoCore.ITcoTaskStatus
VAR_INPUT
