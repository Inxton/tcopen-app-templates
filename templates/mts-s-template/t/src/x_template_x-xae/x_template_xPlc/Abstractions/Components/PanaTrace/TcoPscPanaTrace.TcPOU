    <Method Name="InvokeSendReport" Id="{e1dd218b-3017-4ea9-ba4e-4c013d4122a4}" FolderPath="Public\">
      <Declaration><![CDATA[METHOD InvokeSendReport : TcoCore.ITcoTaskStatus
VAR_INPUT
	inSerialNo : STRING;
	inRfid : STRING;
