InvokeSendReport := _sendReportTask.Invoke();]]></ST>
      </Implementation>
    </Method>
    <Property Name="IsNok" Id="{b0ca4d1c-2485-43c4-a614-e64c6e65f21d}">
      <Declaration><![CDATA[PROPERTY IsNok : BOOL]]></Declaration>
      <Get Name="Get" Id="{1709e71f-52a3-4895-9767-ebde9ecad6ba}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[IsNok := _tracabilityResponse = 'NG';]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="IsOk" Id="{9ecc4609-0e4b-4452-8a40-283ac2410327}">
      <Declaration><![CDATA[PROPERTY IsOk : BOOL]]></Declaration>
      <Get Name="Get" Id="{ca41113a-a84c-4af1-bc11-12bddcd196fa}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[IsOk := _tracabilityResponse = 'OK';]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="IsProduction" Id="{733939aa-1299-49b4-a08c-385168aa00b8}">
      <Declaration><![CDATA[PROPERTY IsProduction : BOOL]]></Declaration>
      <Get Name="Get" Id="{d6f196f7-d683-46d0-a300-91d0a5eaba74}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[IsProduction := (MID(STR:=_dataFromTracability, LEN := 3, POS := 1) = 'PRD') AND LEN(_dataFromTracability) > 4;
]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="IsRetest" Id="{73d06387-f47a-4228-9ecb-25c209a02fc3}">
      <Declaration><![CDATA[PROPERTY IsRetest : BOOL]]></Declaration>
      <Get Name="Get" Id="{328ab792-9192-40aa-88bc-0bc2da81b739}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[IsRetest := MID(STR:=_dataFromTracability, LEN := 3, POS := 1) = 'RST';]]></ST>
        </Implementation>
      </Get>
    </Property>
