      <Declaration><![CDATA[METHOD InitializePanaTrace : BOOL
VAR_INPUT
	SerialNo : STRING;
	Rfid : STRING;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[InitializePanaTrace := SendReport(SerialNo:= SerialNo, Rfid := Rfid, Result:= 'FAIL');]]></ST>
      </Implementation>
    </Method>
