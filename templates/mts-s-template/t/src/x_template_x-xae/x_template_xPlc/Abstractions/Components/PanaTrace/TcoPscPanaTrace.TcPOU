      <Declaration><![CDATA[PROPERTY PUBLIC InitializePanaTraceTask : REFERENCE TO TcoCore.TcoTask]]></Declaration>
      <Get Name="Get" Id="{bcebb9fa-23ec-47c6-89d7-fa5aba6beffc}">
