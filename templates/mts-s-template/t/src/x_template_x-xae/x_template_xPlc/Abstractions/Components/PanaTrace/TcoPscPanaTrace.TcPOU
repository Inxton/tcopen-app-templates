    <Method Name="InvokePcbWedding" Id="{e51d5bf7-d927-41db-aed2-12f986fe8373}" FolderPath="Public\">
      <Declaration><![CDATA[METHOD InvokePcbWedding : TcoCore.ITcoTaskStatus
