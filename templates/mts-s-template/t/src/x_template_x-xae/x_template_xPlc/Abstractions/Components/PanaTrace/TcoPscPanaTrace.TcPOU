<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="TcoPscPanaTrace" Id="{69a27127-1f94-4fa8-b2cf-cd51976d866b}" SpecialFunc="None">
    <Declaration><![CDATA[(*~
	<docu>
		<summary>
			Panasonic Tracability component. 
			<code>
			tracability(IpAddress:= 'localhost', Port:= 12000, Workplace:= 'ST1');
			</code>
		</summary>				
	</docu>	
~*)
{attribute addProperty Name "<#Panasonic PanaTrace#>"}
{attribute wpf [Group(Layout.Stack)]}
FUNCTION_BLOCK TcoPscPanaTrace EXTENDS TcoCore.TcoComponent
VAR_INPUT

END_VAR
VAR_OUTPUT
END_VAR
VAR

	
	{attribute addProperty Name "<#Progress#>"}
	_progress : UINT;
	{attribute addProperty Name "<#Get Status Progress#>"}
	_statusProgress : UINT;
	
	{attribute addProperty Name "<#Config#>"}
	_config : TcoPscPanaTraceConfig;
	{attribute addProperty Name "<#Status#>"}
	_status : TcoPscPanaTraceStatus;
	{attribute addProperty Name "<#Control#>"}
	_control : TcoPscPanaTraceControl;
	
	{attribute addProperty Name "<#Status#>"}
	_statusPanaTrace : eTcoPscPanaTraceStatus := eTcoPscPanaTraceStatus.Request;
	
	
	
	{attribute addProperty Name "<#Error Message#>"}
	_errorMessage : STRING;
	
	{attribute addProperty Name "<#Response from tracability#>"}
	_tracabilityResponse : STRING;
	{attribute addProperty Name "<#Data from tracability#>"}
	_dataFromTracability : STRING;
	
	{attribute addProperty Name "<#Restore#>"}
	_restoreTask : TcoCore.TcoTask(THIS^);
	{attribute addProperty Name "<#Confirm Serial Number#>"}
	_confirmSerialNoTask : TcoCore.TcoTask(THIS^);
	{attribute addProperty Name "<#Generate Serial Number#>"}
	_GenerateSerialNoTask : TcoCore.TcoTask(THIS^);
	{attribute addProperty Name "<#Pcb Wedding#>"}
	_pcbWeddingTask : TcoCore.TcoTask(THIS^);
	{attribute addProperty Name "<#Send Report#>"}
	_sendReportTask : TcoCore.TcoTask(THIS^);
	{attribute addProperty Name "<#Initialize#>"}
	_initializeTask : TcoCore.TcoTask(THIS^);
	{attribute addProperty Name "<#Get Status#>"}
	_getStatusTask : TcoCore.TcoTask(THIS^);
	

	
	_generateSerialNo : TcoCore.TcoRemoteTask(THIS^);
	_confirmSerialNo : TcoCore.TcoRemoteTask(THIS^);
	_sendReport : TcoCore.TcoRemoteTask(THIS^);
	_pcbWedding : TcoCore.TcoRemoteTask(THIS^);
	_getStatus : TcoCore.TcoRemoteTask(THIS^);
	
	//~
	// syntax for builder to ignore
	_timer : TON;
	_bussyTimer : TON;
	//~

	
//	actualWeddingCounter : INT;
//	_manualWeddingCounter : INT;
	i : INT;
END_VAR
VAR CONSTANT
	{attribute clr [RenderIgnore()]}
	MAX_PCB_WEDDINGS          : INT := 9;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[SUPER^();
_status.Progress := _progress;
_status.StatusProgress := _statusProgress;
_status.StatusPanaTrace := _statusPanaTrace;
_status.DataFromTracability := _dataFromTracability;
_status.TracabilityResponse := _tracabilityResponse;

_confirmSerialNoTask.Enabled := TRUE;

IF _confirmSerialNoTask.Execute() THEN
    IF ConfirmSerialNo(SerialNo := _control.PartSerialNo, Rfid := _control.Rfid,inReference:=_control.ReferenceId) THEN
        _confirmSerialNoTask.DoneWhen(inCondition := TRUE);
    END_IF;
END_IF

_GenerateSerialNoTask.Enabled := _config.HasSerialNoGeneration;

IF _GenerateSerialNoTask.Execute() THEN
    IF GenerateSerialNo(Rfid := _control.Rfid,inReference:= _control.ReferenceId) THEN
        _GenerateSerialNoTask.DoneWhen(inCondition := TRUE);
    END_IF;
END_IF

_sendReportTask.Enabled := TRUE;

IF _sendReportTask.Execute() THEN
    IF SendReport(SerialNo := _control.PartSerialNo, Rfid := _control.Rfid, Result := _control.Result) THEN
        _sendReportTask.DoneWhen(inCondition := TRUE);
    END_IF;
END_IF



_pcbWeddingTask.Enabled := _config.HasPcbWedding;

IF _pcbWeddingTask.Execute() THEN
    IF THIS^.IsService THEN
        _control.ManualWeddingCounter := 1;

        IF PcbWedding(SerialNo := _control.PartSerialNo, Rfid := _control.Rfid, PcbDmc := _control.PcbSerialNo, _control.ManualWeddingCounter) THEN
            _control.ManualWeddingCounter := _control.ManualWeddingCounter + 1;
            _pcbWeddingTask.DoneWhen(inCondition := TRUE);
        END_IF
    ELSE
        IF PcbWedding(SerialNo := _control.PartSerialNo, Rfid := _control.Rfid, PcbDmc := _control.PcbSerialNo, _control.PcbIndex) THEN
            _pcbWeddingTask.DoneWhen(inCondition := TRUE);
        END_IF;
    END_IF
END_IF

_initializeTask.Enabled := TRUE;

IF _initializeTask.Execute() THEN

    IF InitializePanaTrace(SerialNo := _control.PartSerialNo, Rfid := _control.Rfid) THEN
        _initializeTask.DoneWhen(TRUE);
    END_IF

END_IF

_getStatusTask.Enabled := TRUE;
IF _getStatusTask.Execute() THEN

    IF GetStatus() THEN
        _getStatusTask.DoneWhen(TRUE);
    END_IF
END_IF;

//*************RESTORE********************

_restoreTask.Enabled := TRUE;

IF _restoreTask.Execute() THEN
    Restore();
    _restoreTask.DoneWhen(inCondition := TRUE);
END_IF

//****************************************]]></ST>
    </Implementation>
    <Folder Name="Internal" Id="{771f612d-bc9d-4835-bb03-c95a95c4bc7e}" />
    <Folder Name="Public" Id="{150f7750-bc17-4a21-b8bb-a7d83ad1f87b}" />
    <Folder Name="Tasks" Id="{74be1fa8-2b8e-4567-873d-fe79e492f3fc}" />
    <Method Name="AddPcbToWeddingBuffer" Id="{941306d1-f476-4d5b-95a4-ccd568115a24}">
      <Declaration><![CDATA[METHOD AddPcbToWeddingBuffer : BOOL
VAR_INPUT
	Pcb : STRING;
	Index : UINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[AddPcbToWeddingBuffer := FALSE;

IF Index > MAX_PCB_WEDDINGS then
	_control.PcbSerials[MAX_PCB_WEDDINGS] := pcb;
ELSE
	_control.PcbSerials[Index] := pcb;
END_IF

AddPcbToWeddingBuffer := TRUE;]]></ST>
      </Implementation>
    </Method>
    <Method Name="ClearPcbWeddingBuffer" Id="{1ddf5b75-e22a-4b60-b648-874c044e0433}">
      <Declaration><![CDATA[METHOD ClearPcbWeddingBuffer
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[_control.ActualWeddingCounter  := 1;

FOR i:=0 TO MAX_PCB_WEDDINGS BY 1 DO
	_control.PcbSerials[i] := '';
END_FOR]]></ST>
      </Implementation>
    </Method>
    <Property Name="Config" Id="{a0c152ba-91f5-004b-39e0-32a49b77de38}">
      <Declaration><![CDATA[
PROPERTY Config : REFERENCE TO TcoPscPanaTraceConfig]]></Declaration>
      <Get Name="Get" Id="{80f0f790-65df-0561-125d-e0f3390bd072}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[Config REF= _config;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="ConfirmSerialNo" Id="{45e98d7c-5709-4ff7-a255-c43ed66a162b}" FolderPath="Internal\">
      <Declaration><![CDATA[(*~
	<docu>
		<summary>
			Checks if the part with serial number can be processed on actual station. Only parts with "OK" status from tracability can be allowed to process. 
		</summary>				
	</docu>	
~*)
METHOD ConfirmSerialNo : BOOL
VAR_INPUT
    SerialNo : STRING;
    Rfid : STRING;
    inReference : STRING;

END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[ConfirmSerialNo := FALSE;


//*************************************************************************************************** 
IF _progress = 0 THEN
	_control.PartSerialNo := SerialNo;
	_control.Rfid := Rfid;
	_control.Result := '';
	_control.PcbSerialNo := '';
	
	ClearPcbWeddingBuffer();
	
	_progress := 10;
END_IF
//*************************************************************************************************** 

//***************************************************************************************************
IF _progress = 10 THEN	
	_bussyTimer(IN:= FALSE, PT:= T#0MS);
	
	IF GetStatus() THEN
		_progress := 11;
	END_IF
END_IF
//*************************************************************************************************** 

//*************************************************************************************************** 
IF _progress = 11 THEN	

	CASE _statusPanaTrace OF
		eTcoPscPanaTraceStatus.Request:
  			_progress := 20;
		eTcoPscPanaTraceStatus.OFF, eTcoPscPanaTraceStatus.Bussy: 
			_bussyTimer(IN:= TRUE, PT:= _config.TimeToRepeatStatusWhenBussy);
			
			IF _bussyTimer.Q THEN
				_progress := 10;
			END_IF
		eTcoPscPanaTraceStatus.NoConnection:
			_bussyTimer(IN:= TRUE, PT:= _config.TimeToRepeatStatusWhenConnectionTimout);
			
			IF _bussyTimer.Q THEN
				_progress := 10;
			END_IF
		ELSE
			Messenger.Warning('<#Panatrace is not ready for confirm serial number command#>');
	END_CASE	
END_IF
//*************************************************************************************************** 

//*************************************************************************************************** 
IF _progress = 20 THEN	
	Messenger.Info('<#Confirm serial number command running#>');
	
	_control.PartSerialNo := SerialNo;
	_control.Rfid := Rfid;
	_control.Result := '';
	_control.PcbSerialNo := '';
	
	IF _confirmSerialNo.Invoke().Done THEN
		_confirmSerialNo.Restore();
		_progress := 30;
	END_IF
END_IF
//*************************************************************************************************** 

//*************************************************************************************************** 
IF _progress = 30 THEN	
	IF NOT IsOk THEN
		_statusPanaTrace := eTcoPscPanaTraceStatus.Request;
	ELSIF _config.HasSerialNoGeneration THEN
		_statusPanaTrace := eTcoPscPanaTraceStatus.Generating;
	ELSIF _config.HasPcbWedding THEN
		_statusPanaTrace := eTcoPscPanaTraceStatus.Wedding;
	ELSE
		_statusPanaTrace := eTcoPscPanaTraceStatus.Report;
	END_IF
	
	ConfirmSerialNo := TRUE;
END_IF
//*************************************************************************************************** 

]]></ST>
      </Implementation>
    </Method>
    <Property Name="ConfirmSerialNoTask" Id="{9b9b02e0-d2fc-4e1b-9c89-963b5a74372d}" FolderPath="Tasks\">
      <Declaration><![CDATA[PROPERTY PUBLIC ConfirmSerialNoTask : REFERENCE TO TcoCore.TcoTask]]></Declaration>
      <Get Name="Get" Id="{6c6ced7a-dc2a-4c1d-b115-df172b7d84aa}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[ConfirmSerialNoTask ref=_confirmSerialNoTask;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="DataFromTracability" Id="{fff3e72d-73c0-45d1-a5c2-6de2f3416e4a}">
      <Declaration><![CDATA[PROPERTY DataFromTracability : STRING]]></Declaration>
      <Get Name="Get" Id="{5394bbaf-93cd-41d1-91d5-27e42532a736}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[DataFromTracability := _dataFromTracability;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="GeneratedSerialNo" Id="{eb94f4b2-5a75-48ba-8327-023f697963d4}">
      <Declaration><![CDATA[PROPERTY GeneratedSerialNo : String]]></Declaration>
      <Get Name="Get" Id="{d09bd1d8-cfc9-45fd-8540-9beb0e74a2ee}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[GeneratedSerialNo := _status.GeneratedSerialNo;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="GenerateSerialNo" Id="{b73777da-93b3-4344-bc4a-3667ee7767d6}" FolderPath="Internal\">
      <Declaration><![CDATA[(*~
	<docu>
		<summary>
			Generates serial number for plc. Station has to be allowed to generate serial no from customer admin. Part serial No has to be empty when seding generate serial number command.
		</summary>				
	</docu>	
~*)
METHOD GenerateSerialNo : BOOL
VAR_INPUT
    Rfid : STRING;
    inReference : STRING;

END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[GenerateSerialNo := FALSE;



//*************************************************************************************************** 
IF _progress = 0 THEN
	_control.Rfid := Rfid;
	_control.PartSerialNo := '';
	_control.Result := '';
	
	_progress := 1;
END_IF
//*************************************************************************************************** 

//*************************************************************************************************** 
IF _progress = 1 THEN	
	Messenger.Programming('<#Generate serial number command is not allowed#>');
	
	IF _config.HasSerialNoGeneration THEN
		_progress := 10;
	END_IF
END_IF
//*************************************************************************************************** 

//***************************************************************************************************
IF _progress = 10 THEN	
	_bussyTimer(IN:= FALSE, PT:= T#0MS);
	
	IF GetStatus() THEN
		_progress := 11;
	END_IF
END_IF
//*************************************************************************************************** 

//*************************************************************************************************** 
IF _progress = 11 THEN	

	CASE _statusPanaTrace OF
		eTcoPscPanaTraceStatus.Generating:
			_progress := 20;
		eTcoPscPanaTraceStatus.Request:
  			_progress := 12;
		eTcoPscPanaTraceStatus.OFF, eTcoPscPanaTraceStatus.Bussy: 
			_bussyTimer(IN:= TRUE, PT:= _config.TimeToRepeatStatusWhenBussy);
			
			IF _bussyTimer.Q THEN
				_progress := 10;
			END_IF
		eTcoPscPanaTraceStatus.NoConnection:
			_bussyTimer(IN:= TRUE, PT:= _config.TimeToRepeatStatusWhenConnectionTimout);
			
			IF _bussyTimer.Q THEN
				_progress := 10;
			END_IF
		ELSE
			Messenger.Warning('<#Panatrace is not ready for generate serial number command#>');
	END_CASE		

END_IF
//*************************************************************************************************** 

//*************************************************************************************************** 
IF _progress = 12 THEN
	Messenger.Info('<Confirm serial number command running#>');
	
	_control.Rfid := Rfid;
	_control.PartSerialNo := '';
	_control.Result := '';
	
	IF _confirmSerialNo.Invoke().Done THEN
		_confirmSerialNo.Restore();
		_progress := 15;
	END_IF
END_IF
//*************************************************************************************************** 

//*************************************************************************************************** 
IF _progress = 15 THEN
	_timer(IN:= TRUE, PT:= T#100MS);
	
	IF _timer.Q THEN
		_progress := 20;
	END_IF
END_IF
//*************************************************************************************************** 

//*************************************************************************************************** 
IF _progress = 20 THEN	
	Messenger.Programming('<#Generate serial number command running#>');
	
	_control.Rfid := Rfid;
	_control.PartSerialNo := '';
	_control.Result := '';
	
	IF _generateSerialNo.Invoke().Done THEN
		_generateSerialNo.Restore();
		_progress := 30;
	END_IF
END_IF
//*************************************************************************************************** 

//*************************************************************************************************** 
IF _progress = 30 THEN	
	IF NOT IsOk THEN
		_statusPanaTrace := eTcoPscPanaTraceStatus.Request;
	ELSIF _config.HasPcbWedding THEN
		_statusPanaTrace := eTcoPscPanaTraceStatus.Wedding;
	ELSE
		_statusPanaTrace := eTcoPscPanaTraceStatus.Report;
	END_IF
	
	GenerateSerialNo := TRUE;
END_IF
//*************************************************************************************************** 
]]></ST>
      </Implementation>
    </Method>
    <Property Name="GenerateSerialNoTask" Id="{f43d60f3-db34-4504-8049-b4f1c1fbd125}" FolderPath="Tasks\">
      <Declaration><![CDATA[PROPERTY PUBLIC GenerateSerialNoTask : REFERENCE TO TcoCore.TcoTask]]></Declaration>
      <Get Name="Get" Id="{63023ec6-79f2-4835-9532-fd68a1685fb4}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[GenerateSerialNoTask ref=_generateSerialNoTask;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="GetStatus" Id="{8f6328a5-da59-493a-bcc8-bb851ed66ac5}" FolderPath="Internal\">
      <Declaration><![CDATA[METHOD GetStatus : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[GetStatus := FALSE;



//*************************************************************************************************** 
IF _statusProgress = 0 THEN
	_control.PartSerialNo := '';
	_control.Rfid := '';
	_control.Result := '';
	_control.PcbSerialNo := '';
	
	_statusProgress := 20;
END_IF
//*************************************************************************************************** 

//*************************************************************************************************** 
IF _statusProgress = 20 THEN	
	Messenger.Programming('<#Get status command running#>');
	
	IF _getStatus.Invoke().Done THEN
		_getStatus.Restore();
		_statusProgress := 30;
	END_IF
END_IF
//*************************************************************************************************** 

//*************************************************************************************************** 
IF _statusProgress = 30 THEN
	
	CASE STRING_TO_UINT(MID(STR:= _dataFromTracability, LEN:= 1, POS:= 1)) OF
		eTcoPscPanaTraceStatus.Generating:
			_statusPanaTrace := eTcoPscPanaTraceStatus.Generating;
		eTcoPscPanaTraceStatus.Request :
			_statusPanaTrace := eTcoPscPanaTraceStatus.Request;
		eTcoPscPanaTraceStatus.Wedding :
			_statusPanaTrace := eTcoPscPanaTraceStatus.Wedding;
		eTcoPscPanaTraceStatus.Report :
			_statusPanaTrace := eTcoPscPanaTraceStatus.Report;
		eTcoPscPanaTraceStatus.OFF :
			_statusPanaTrace := eTcoPscPanaTraceStatus.OFF;
		eTcoPscPanaTraceStatus.Bussy :
			_statusPanaTrace := eTcoPscPanaTraceStatus.Bussy;
	ELSE
		_statusPanaTrace := eTcoPscPanaTraceStatus.NoConnection;
	END_CASE

	
	GetStatus := TRUE;
END_IF
//*************************************************************************************************** 

]]></ST>
      </Implementation>
    </Method>
    <Property Name="GetStatusTask" Id="{dc47a01e-fe78-4cd5-9ee7-fbcb7655fe2f}" FolderPath="Tasks\">
      <Declaration><![CDATA[PROPERTY PUBLIC GetStatusTask : REFERENCE TO TcoCore.TcoTask]]></Declaration>
      <Get Name="Get" Id="{bc2a11fe-7be5-4d5b-a3bf-4009b6d9afe8}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[GetStatusTask ref=_getStatusTask;]]></ST>
        </Implementation>
      </Get>
    </Property>
