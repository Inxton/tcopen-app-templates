    <Method Name="SendReport" Id="{a807f5cf-f10d-441e-956a-3dc06559e920}" FolderPath="Internal\">
      <Declaration><![CDATA[(*~
	<docu>
		<summary>
			Sends report with data to tracabilty. Result has to be string PASS or FAIL.
		</summary>				
	</docu>	
~*)
METHOD SendReport : BOOL
VAR_INPUT
	SerialNo : STRING;
	Rfid : STRING;
	Result : STRING;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[SendReport := FALSE;



//*************************************************************************************************** 
IF _progress = 0 THEN
	_control.PartSerialNo := SerialNo;
	_control.Rfid := Rfid;
	_control.Result := Result;
	_control.PcbSerialNo := '';
	
	_progress := 10;
END_IF
//*************************************************************************************************** 

//*************************************************************************************************** 
IF _progress = 10 THEN	
	_bussyTimer(IN:= FALSE, PT:= T#0MS);
	
	IF GetStatus() THEN
		_progress := 11;
	END_IF
END_IF
//*************************************************************************************************** 

//*************************************************************************************************** 
IF _progress = 11 THEN	
	
	CASE _statusPanaTrace OF
		eTcoPscPanaTraceStatus.Generating:
			_progress := 20;
		eTcoPscPanaTraceStatus.Wedding:
			_progress := 30;
		eTcoPscPanaTraceStatus.Report:
			_progress := 40;
		eTcoPscPanaTraceStatus.OFF, eTcoPscPanaTraceStatus.Bussy:
			_bussyTimer(IN:= TRUE, PT:= _config.TimeToRepeatStatusWhenBussy);
			
			IF _bussyTimer.Q THEN
				_progress := 10;
			END_IF
		eTcoPscPanaTraceStatus.NoConnection:
			_bussyTimer(IN:= TRUE, PT:= _config.TimeToRepeatStatusWhenConnectionTimout);
			
			IF _bussyTimer.Q THEN
				_progress := 10;
			END_IF
	ELSE
		_progress := 100;
	END_CASE
END_IF
//*************************************************************************************************** 

//*************************************************************************************************** 
IF _progress = 20 THEN	
	Messenger.Info('<#Generate serial no command running#>');
	
	IF _generateSerialNo.Invoke().Done THEN
		_generateSerialNo.Restore();
		_progress := 21;
	END_IF
END_IF
//*************************************************************************************************** 

//***************************************************************************************************
IF _progress = 21 THEN
	_timer(IN:= TRUE, PT:= T#100MS);
	
	IF _timer.Q THEN
		_progress := 25;
	END_IF
END_IF
//*************************************************************************************************** 

//*************************************************************************************************** 
IF _progress = 25 THEN	
	
	IF NOT IsOk THEN
		_progress := 100;
	ELSIF _config.HasPcbWedding THEN
		//_status := enumPscPanaTraceStatus.Wedding;
		_progress := 10;
	ELSE
		//_status := enumPscPanaTraceStatus.Report;
		_progress := 10;
	END_IF
END_IF
//*************************************************************************************************** 

//*************************************************************************************************** 
IF _progress = 30 THEN	
	_control.PcbSerialNo := 'Reset';
	Messenger.Info('<#Pcb wedding command running#>');
	
	IF _pcbWedding.Invoke().Done THEN
		_pcbWedding.Restore();
		_progress := 31;
	END_IF
END_IF
//*************************************************************************************************** 

//***************************************************************************************************
IF _progress = 31 THEN
	_timer(IN:= TRUE, PT:= T#100MS);
	
	IF _timer.Q THEN
		_progress := 35;
	END_IF
END_IF
//*************************************************************************************************** 

//*************************************************************************************************** 
IF _progress = 35 THEN	
	IF NOT IsOk THEN
		_progress := 100;
	ELSE
		//_status := enumPscPanaTraceStatus.Report;
		_progress := 10;
	END_IF
END_IF
//*************************************************************************************************** 

//*************************************************************************************************** 
IF _progress = 40 THEN	
	Messenger.Info('<#Send report command running#>');
	
	_control.PartSerialNo := SerialNo;
	_control.Rfid := Rfid;
	_control.Result := Result;
	_control.PcbSerialNo := '';
	
	IF _sendReport.Invoke().Done THEN
		_sendReport.Restore();
		_progress := 100;
	END_IF
END_IF
//*************************************************************************************************** 

//*************************************************************************************************** 
IF _progress = 100 THEN	
	_statusPanaTrace := eTcoPscPanaTraceStatus.Request;
	SendReport := TRUE;
END_IF
//*************************************************************************************************** 
]]></ST>
      </Implementation>
    </Method>
