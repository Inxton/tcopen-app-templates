	inReference : STRING;

END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[_control.Rfid := inRfid;
_control.ReferenceId := inReference;

InvokeGenerateSerialNo := _GenerateSerialNoTask.Invoke();]]></ST>
      </Implementation>
    </Method>
