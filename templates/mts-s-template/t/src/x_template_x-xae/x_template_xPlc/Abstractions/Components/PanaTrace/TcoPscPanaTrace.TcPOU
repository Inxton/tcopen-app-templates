    <Method Name="PcbWedding" Id="{b28e9bde-5659-4095-b791-55bf603de067}" FolderPath="Internal\">
      <Declaration><![CDATA[(*~
	<docu>
		<summary>
			For all pcbs that are assembled into the main part, it is needed to call PcbWedding method. 
			If necessary call method multiple times in one station, once for each pcb inserted into the part. 
			After NG response from any wedding, to retry wedding confirm serial number command is necessary, 
			and all previous weddings has to be sent to panatrace. 
		</summary>				
	</docu>	
~*)
METHOD PcbWedding : BOOL
VAR_INPUT
	SerialNo : STRING;
	Rfid : STRING;
	PcbDmc : STRING;
	PcbIndex : UINT;   //used only from 1 to 9!
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[PcbWedding := FALSE;



//***************************************************************************************************
IF _progress = 0 THEN
	_control.PartSerialNo := SerialNo;
	_control.Rfid := Rfid;
	_control.Result := '';
	_control.PcbSerialNo := PcbDmc;
	
	AddPcbToWeddingBuffer(PcbDmc,PcbIndex);
	
	_progress := 1;
END_IF
//*************************************************************************************************** 

//***************************************************************************************************
IF _progress = 1 THEN	
	Messenger.Programming('<#PcbWedding command is not allowed#>');
	
	IF _config.HasPcbWedding THEN
		_progress := 10;
	END_IF
END_IF
//*************************************************************************************************** 

//***************************************************************************************************
IF _progress = 10 THEN
	_bussyTimer(IN:= FALSE, PT:= T#0MS);
	
	IF GetStatus() THEN
		_progress := 11;
	END_IF
END_IF
//*************************************************************************************************** 

//***************************************************************************************************
IF _progress = 11 THEN	

	CASE _statusPanaTrace OF
		eTcoPscPanaTraceStatus.Wedding:  
			_progress := 20;
		eTcoPscPanaTraceStatus.Request:     
			_progress := 12;
		eTcoPscPanaTraceStatus.OFF, eTcoPscPanaTraceStatus.Bussy:
			_bussyTimer(IN:= TRUE, PT:= _config.TimeToRepeatStatusWhenBussy);
			
			IF _bussyTimer.Q THEN
				_progress := 10;
			END_IF
		eTcoPscPanaTraceStatus.NoConnection:
			_bussyTimer(IN:= TRUE, PT:= _config.TimeToRepeatStatusWhenConnectionTimout);
			
			IF _bussyTimer.Q THEN
				_progress := 10;
			END_IF
		ELSE
			Messenger.Warning('<#Panatrace is not ready for pcb wedding command#>');
	END_CASE	

END_IF
//*************************************************************************************************** 

//***************************************************************************************************
IF _progress = 12 THEN
	_control.PartSerialNo := SerialNo;
	_control.Rfid := Rfid;
	_control.PcbSerialNo := '';
	_control.Result := '';
	
	Messenger.Info('<#Confirm serial number command running#>');
	
	_control.ActualWeddingCounter := 1;
	
	IF _confirmSerialNo.Invoke().Done THEN
		_progress := 15;
	END_IF
END_IF
//*************************************************************************************************** 

//***************************************************************************************************
IF _progress = 15 THEN
	_timer(IN:= TRUE, PT:= T#100MS);
	
	IF _timer.Q THEN
		_progress := 20;
	END_IF
END_IF
//*************************************************************************************************** 

//***************************************************************************************************
IF _progress = 20 THEN	
	
	_control.PartSerialNo := SerialNo;
	_control.Rfid := Rfid;
	_control.Result := '';
	
	IF _control.ActualWeddingCounter > MAX_PCB_WEDDINGS THEN
		_control.ActualWeddingCounter := MAX_PCB_WEDDINGS;
	END_IF
	
	_control.PcbSerialNo := _control.PcbSerials[_control.ActualWeddingCounter];	
	
	Messenger.Info('<#Pcb wedding command running#>');
	
	IF _pcbWedding.Invoke().Done THEN
		_pcbWedding.Restore();
		_progress := 30;
	END_IF
END_IF
//*************************************************************************************************** 

//***************************************************************************************************
IF _progress = 30 THEN	
	IF IsOk THEN
		
		_statusPanaTrace := eTcoPscPanaTraceStatus.Report;
		_control.ActualWeddingCounter := _control.ActualWeddingCounter + 1;
		
		IF _control.ActualWeddingCounter > PcbIndex THEN
			// all pcbs from buffer were sent to pana trace
			_progress := 40;
		ELSE
			// repeat wedding til all pcbs are sent
			_progress := 1;
		END_IF
	
	ELSE
		_statusPanaTrace := eTcoPscPanaTraceStatus.Request;
		_progress := 40;
	END_IF	
END_IF
//*************************************************************************************************** 

//***************************************************************************************************
IF _progress = 40 THEN	
	
	PcbWedding := TRUE;
END_IF
//*************************************************************************************************** 
]]></ST>
      </Implementation>
    </Method>
    <Property Name="PcbWeddingTask" Id="{0dc24c6f-b860-4d50-8f81-9fc05a1b717a}" FolderPath="Tasks\">
      <Declaration><![CDATA[PROPERTY PUBLIC PcbWeddingTask : REFERENCE TO TcoCore.TcoTask]]></Declaration>
