<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="TcoEq2Transfer" Id="{08fb0a49-02ab-4e4f-9a2d-a7e09c575beb}" SpecialFunc="None">
    <Declaration><![CDATA[{attribute wpf [Container(Layout.Stack)]}
{attribute wpf [Group(Layout.Scroll)]}
FUNCTION_BLOCK TcoEq2Transfer EXTENDS TcoCore.TcoComponent


VAR
	
	_config:TcoEq2Transfer_Config;
	_status:TcoEq2Transfer_Status;
	_control:TcoEq2Transfer_Control;
    _components:TcoEq2TransferComponents:= (Parent := THIS^);
	_handleIncomingPaletteTask:TcoCore.TcoTask(THIS^);
	_handleOutgoingPaletteTask:TcoCore.TcoTask(THIS^);
	_autoTask:TcoCore.TcoTask(THIS^);
	_restoreTask:TcoCore.TcoTask(THIS^);
	
	_progressIncomming:INT;
	_progressOutgoing:INT;

	{attribute 'hide'} 
	_timerIncoming :  TON;
	{attribute 'hide'} 
	_timerOutcoming :  TON;
	
	{attribute 'hide'} 
	_infoTimer :  TON;
    {attribute 'hide'} 
	_errorTimer :  TON;

	_autoProgress: INT;
	
	 {attribute 'hide'} 
	_timerOptional:  TON;
	_mode: eTcoEq2TransferHandlingMode;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[_handleIncomingPaletteTask.Enabled := NOT _handleOutgoingPaletteTask.Busy;
IF (_handleIncomingPaletteTask.Execute()) THEN

    IF _config.Configuration = eTcoEq2TransferConfiguration.DoubleInSingleOut THEN
		 IF IsService THEN
		   _mode:=_config.Mode;
	   END_IF
        IncomingPaletteDoubleIn(inMode := _mode,
            refProgress := _progressIncomming,
            refStatus := _status,
            refConfig := _config,
            refTimer := _timerIncoming,
            refTask := _handleIncomingPaletteTask);
    ELSIF _config.Configuration = eTcoEq2TransferConfiguration.SingleInDoubleOut THEN
        IncomingPaletteSingleIn(refProgress := _progressIncomming,
            refStatus := _status,
            refConfig := _config,
            refTimer := _timerIncoming,
            refTask := _handleIncomingPaletteTask);
    END_IF;

    CallTimers(TRUE);
    _handleIncomingPaletteTask.ThrowWhen(_errorTimer.Q);

    Messenger.OnCondition(_infoTimer.Q).Info(_status.ActionDescription);
END_IF;

_handleOutgoingPaletteTask.Enabled := NOT _handleIncomingPaletteTask.Busy;
IF (_handleOutgoingPaletteTask.Execute()) THEN
	IF _config.Configuration = eTcoEq2TransferConfiguration.DoubleInSingleOut THEN
    OutgoingPaletteDoubleIn(refProgress := _progressOutgoing,
        refStatus := _status,
        refConfig := _config,
        refTimer := _timerOutcoming,
        refTask := _handleOutgoingPaletteTask);
   ELSIF _config.Configuration = eTcoEq2TransferConfiguration.SingleInDoubleOut THEN
	   IF IsService THEN
		   _mode:=_config.Mode;
	   END_IF
	   OutgoingPaletteSingleIn(refProgress := _progressOutgoing,
        inMode := _mode,
        refStatus := _status,
        refConfig := _config,
        refTimer := _timerOutcoming,
        refTask := _handleOutgoingPaletteTask);
	END_IF
    CallTimers(TRUE);
    _handleOutgoingPaletteTask.ThrowWhen(_errorTimer.Q);
    Messenger.OnCondition(_infoTimer.Q).Info(_status.ActionDescription);
END_IF;

_autoTask.Enabled := TRUE;
IF (_autoTask.Execute()) THEN

    IF _autoProgress = 0 THEN
        _handleOutgoingPaletteTask.Restore();
    END_IF

    IF _autoProgress = 1 THEN
        IF HandleIncommingPalette().Done THEN
            _autoProgress := _autoProgress + 1;
            _handleOutgoingPaletteTask.Restore();
        END_IF

    END_IF;

    IF _autoProgress = 2 THEN
        IF HandleOutgoingPalette().Done THEN
            _autoProgress := 0;
        end_If;
    END_IF

END_IF;

//*************RESTORE********************

_restoreTask.Enabled := TRUE;

IF _restoreTask.Execute() THEN
    Restore();
	_components.TransferUnit.MoveToHome();
    _restoreTask.DoneWhen(inCondition := _components.TransferUnit.AtHome);
END_IF
//****************************************






]]></ST>
    </Implementation>
    <Folder Name="Operations" Id="{ead22d33-2f6b-406d-917a-b49667d2aa8c}" />
    <Folder Name="OperationsInternal" Id="{61bbdb25-9509-4d36-a724-eb4bdf697c9a}" />
    <Folder Name="Tasks" Id="{d7253edc-aac3-4fff-842e-fd2bd0df1392}" />
    <Method Name="AutomatControl" Id="{59b4aed1-1b07-41cb-bbf0-847d8105c235}">
      <Declaration><![CDATA[METHOD AutomatControl : ITcoTaskStatus
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[AutomatControl:=_autoTask.Invoke();]]></ST>
      </Implementation>
    </Method>
    <Method Name="CallTimers" Id="{10ac51b3-e1e9-4519-a329-36cd45b6336a}">
      <Declaration><![CDATA[METHOD CallTimers
VAR_INPUT
	inValue : BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF   THIS^._config.ErrorTime <> T#0S OR NOT inValue THEN  
_errorTimer(IN := inValue, PT := THIS^._config.ErrorTime);
END_IF;
IF   THIS^._config.InfoTime <>T#0S OR NOT inValue THEN  
_infoTimer(IN := inValue, PT := THIS^._config.InfoTime);
END_IF;]]></ST>
      </Implementation>
    </Method>
    <Property Name="Components" Id="{e9dd1b09-9b59-4950-91ab-ece794b321e4}">
      <Declaration><![CDATA[PROPERTY Components : REFERENCE TO TcoEq2TransferComponents
]]></Declaration>
      <Get Name="Get" Id="{683ab001-38a4-43bc-8037-cf2f9bd817ed}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[Components ref=_components;]]></ST>
        </Implementation>
      </Get>
    </Property>
