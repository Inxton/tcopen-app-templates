    <Method Name="InitializeComponents" Id="{fc888b5c-689c-415f-91b8-3adb52477a53}" FolderPath="Initialize\">
      <Declaration><![CDATA[METHOD InitializeComponents
VAR_INST
	DoNothing : BOOL;
	None : BOOL;
END_VAR

VAR
	controlVolage: BOOL;
	controlVoltageDoor: BOOL;
	estop: BOOL;
	presure: BOOL;
	locked: BOOL;
	lock: BOOL;
	opened: BOOL;
	closed: BOOL;
	
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[controlVolage:=FALSE;
controlVoltageDoor:=FALSE;
estop:=FALSE;
presure:=FALSE;

_components.VirtualControlButtons(
	refButtonRecover:= _components.VirtualButtons.StartButton, 
	refButtonSuspend:= _components.VirtualButtons.StopButton, 
	refButtonGround:= None , 
	refButtonAuto:= None, 
	refButtonRecoverLight:= _components.VirtualButtons.StartLight,
	refButtonSuspendLight:= _components.VirtualButtons.StopLight, 
	refButtonGroundLight:= DoNothing, 
	refButtonAutoLight:=  DoNothing);



//_dummyBlinker(inOffTime := T#10000MS, inOnTime := T#10000MS);
(*
closed:=GVL_iXlinker.EC1.EK1200.IA1_EL1809.Channel_8.Input;
locked:=GVL_iXlinker.EC1.EK1200.IA1_EL1809.Channel_9.Input;

IF _setDummyConditionsSuffisient THEN
	controlVolage:=TRUE;
	controlVoltageDoor:=TRUE;
	estop:=FALSE;
	presure:=TRUE;


END_IF;

_components.ModeKey(inoKeyState1:=GVL_iXlinker.EC1.EK1200.IA1_EL1809.Channel_1.Input ,
					inoKeyState2:=GVL_iXlinker.EC1.EK1200.IA1_EL1809.Channel_2.Input);
					
_components.NormalServiceKey(inoSignal:=GVL_iXlinker.EC1.EK1200.IA1_EL1809.Channel_3.Input);
					
_components.ControlButtons(
	inoButtonRecover:=GVL_iXlinker.EC1.EK1200.IA1_EL1809.Channel_4.Input  , 
	inoButtonSuspend:=GVL_iXlinker.EC1.EK1200.IA1_EL1809.Channel_5.Input  , 
	inoButtonGround:=GVL_iXlinker.EC1.EK1200.IA1_EL1809.Channel_6.Input , 
	inoButtonAuto:=GVL_iXlinker.EC1.EK1200.IA1_EL1809.Channel_7.Input, 
	inoButtonRecoverLight:=GVL_iXlinker.EC1.EK1200.QA1_EL2809.Channel_1.Output  , 
	inoButtonSuspendLight:=GVL_iXlinker.EC1.EK1200.QA1_EL2809.Channel_2.Output  , 
	inoButtonGroundLight:=GVL_iXlinker.EC1.EK1200.QA1_EL2809.Channel_3.Output  , 
	inoButtonAutoLight:= GVL_iXlinker.EC1.EK1200.QA1_EL2809.Channel_4.Output );
	

					

_components.GlobalControlVoltage(inoSignal := controlVolage);

_components.LocalControlVoltage(inoSignal := controlVolage);
_components.LocalDoorVoltage(inoSignal := controlVoltageDoor);

_components.EmergencyStop(inoSignal := estop);
_components.AirPresureOk(inoSignal:= presure);


_components.StandardDoor(inoIsLocked := locked,
    inoIsOpen := opened,
    inoLock :=lock);
	
	
_components.BasicDoor(inoIsClosed := closed,
     inoLock := lock);


_components.DoorCicuit();

_components.Zone(inDoorCircuit:=_components.DoorCicuit,
				inEstopActive:=_components.EmergencyStop.Signal,
				inAirPressureOK:= _components.AirPresureOk.Signal);
		
				
_components.Zone.Service();
*)]]></ST>
      </Implementation>
    </Method>
    <Method Name="InitializeComponentsOnce" Id="{78fe5985-ea43-49bb-a2ff-319ea6fb4a1a}" FolderPath="Initialize\">
      <Declaration><![CDATA[METHOD InitializeComponentsOnce
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[_components.DoorCicuit.Restore();
_components.Zone.Restore();



_components.DoorCicuit.AddDoors(inDoor:=_components.StandardDoor);
_components.DoorCicuit.AddDoors(inDoor:=_components.BasicDoor);
_components.DoorCicuit.AddGlobalVoltage(inVoltage:=_components.GlobalControlVoltage);
_components.DoorCicuit.AddLocalVoltage(inVoltage:=_components.LocalControlVoltage);
_components.DoorCicuit.AddLocalDoorsVoltage(inVoltage:=_components.LocalDoorVoltage);


_components.Zone.AddControlledUnit(inControlledUnit:=_cu00x);
_components.Zone.AddControlButtons(inControlButtons:=_components.ControlButtons);
_components.Zone.AddControlButtons(inControlButtons:=_components.VirtualControlButtons);

_components.Zone.AddKeyMode(inKeyMode:=_components.ModeKey);
_components.Zone.AddKeyNormalService(inKeyNormalService:=_components.NormalServiceKey);



]]></ST>
      </Implementation>
    </Method>
    <Method Name="InitializeNotificationPanel" Id="{96b29b2e-24d6-46ba-8aab-c4c454308e47}" FolderPath="Initialize\">
      <Declaration><![CDATA[METHOD InitializeNotificationPanel
VAR
	//~
	icon : Icon;
	new : Icon;
	//~
END_VAR

VAR_INST
	//~
	tixonsOK : BOOL;
	tixonErrorTmr : TON;
	//~
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Context.Environment.Messaging.Suspend();


{region "NOTIFICATION PANEL"}
_notificationPanel.Clear();


icon.Title := '<#Control Voltage#>';
icon.IconType := TO_STRING(eIconType.ControlVoltage);
icon.Signal := Components.GlobalControlVoltage.Signal;
_notificationPanel.addIcon(icon);
icon := new;

icon.Title := '<#Air Pressure#>';
icon.IconType := TO_STRING(eIconType.AirPressure);
icon.Signal := Components.AirPresureOk.Signal;
_notificationPanel.addIcon(icon);
icon := new;

icon.Title := '<#Emergency Stop#>';
icon.IconType := TO_STRING(eIconType.EmergencyStop);
icon.Signal := Components.EmergencyStop.Signal;
_notificationPanel.addIcon(icon);
icon := new;

icon.Title := '<#Safety door#>';
icon.IconType := TO_STRING(eIconType.SafetyDoor);
icon.Signal :=  Components.DoorCicuit.IsLocalDoorsVoltageOk;
_notificationPanel.addIcon(icon);
icon := new;

icon.Title := '<#Doors closed#>';
icon.IconType := TO_STRING(eIconType.DoorClosed);
icon.Signal := Components.DoorCicuit.IsClosed;
_notificationPanel.addIcon(icon);
icon := new;

icon.Title := '<#Doors Locked#>';
icon.IconType := TO_STRING(eIconType.DoorLocked);
icon.Signal := Components.DoorCicuit.IsLocked;
_notificationPanel.addIcon(icon);
icon := new;

icon.Title := '<#Automat Allowed#>';
icon.IconType := TO_STRING(eIconType.AutomatAllowed);
icon.Signal := Components.Zone.Status.State.AllKeysAuto;
_notificationPanel.addIcon(icon);
icon := new;

icon.Title := '<#Process Data Loaded#>';
icon.IconType := TO_STRING(eIconType.ProcessDataLoaded);
icon.Signal := ProcessSettings.Data._EntityId <> '';
_notificationPanel.addIcon(icon);
icon := new;

icon.Title := '<#Technology Data Loaded#>';
icon.IconType := TO_STRING(eIconType.TechnologyDataLoaded);  
icon.Signal := TechnologicalSettings.Data._EntityId <> '';
_notificationPanel.addIcon(icon);
icon := new;

icon.Title := '<#Manipulator#>';
icon.IconType := 'AxisArrow';  
/// Recommend to set a backing field in the affected CUs and accessing it through a property, because the below line WILL cause the the plc to crash in the first cycle!!! 
//icon.Signal := NOT _cu00x.Components.MultiAxis.Axis_1.AxisStatus.Error;
_notificationPanel.addIcon(icon);
icon := new;
	 
icon.Title := '<#Robots#>';
icon.IconType := TO_STRING(eIconType.Robot);  
icon.Signal :=  _cu00x.Components.KukaKrc4.Status.State.ExternalAutomatic AND NOT _cu00x.Components.KukaKrc4.Status.State.Error;
_notificationPanel.addIcon(icon);
icon := new;
	 

icon.Title := '<#Cameras#>';
icon.IconType := 'CameraOutline';  
icon.Signal := NOT _cu00x.Components.Cam.Status.SignalStatus.Error;
_notificationPanel.addIcon(icon);
icon := new;
	 
icon.Title := '<#Laser#>';
icon.IconType := 'Qrcode';
//icon.Signal := _cu00x.Components.KeyenceLaser.Status.MachineStatus.IsConnection;
_notificationPanel.addIcon(icon);
icon := new;

///Tixon Auto from project 2400620
//tixonErrorTmr(IN := (NOT _cu00x.Components.Tixon.Status.Ready AND NOT _cu00x.Components.Tixon.RequestSrcewTask.Busy) , PT := T#3S );
tixonsOK := NOT tixonErrorTmr.Q; 

icon.Title := 'TIXON';
icon.IconType := 'Bolt';  
icon.Signal := tixonsOK;
_notificationPanel.addIcon(icon);
icon := new;
	 
_notificationPanel();
{endregion}
 Context.Environment.Messaging.Resume();]]></ST>
      </Implementation>
    </Method>
    <Property Name="InternalStorage" Id="{311fed79-b6f6-44c2-8bf8-ced928984e77}">
