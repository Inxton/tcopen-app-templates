END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[retVal := FALSE;
IF inCuId = eStations.CU00x THEN
	 retVal := TRUE;// Components.Zone1.Status.State.AnyKeyManual AND Components.ControlVoltages.R1.GlobalControlVoltage.Signal;
END_IF;


AllowManual := retVal;]]></ST>
      </Implementation>
    </Method>
