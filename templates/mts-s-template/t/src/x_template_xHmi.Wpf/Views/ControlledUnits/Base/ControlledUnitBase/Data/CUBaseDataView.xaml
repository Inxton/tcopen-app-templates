<UserControl x:Class="x_template_xPlc.CUBaseDataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
               xmlns:p="clr-namespace:x_template_xHmi.Wpf.Properties"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:x_template_xPlc" xmlns:vortex="http://vortex.mts/xaml"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid x:Name="Element" Grid.IsSharedSizeScope="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition ></RowDefinition>

        </Grid.RowDefinitions>
        <vortex:RenderableContentControl DataContext="{Binding Component }" PresentationType="InfoTasks"></vortex:RenderableContentControl>

        <TabControl Grid.Row="1">
            <TabItem Header="{x:Static p:strings.StationProcessData}" DataContext="{Binding Component}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"></RowDefinition>
                        <RowDefinition></RowDefinition>

                    </Grid.RowDefinitions>
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <ToggleButton 
                        materialDesign:ToggleButtonAssist.OnContent="{materialDesign:PackIcon Kind=Play}"
                          Content="{materialDesign:PackIcon Kind=Stop}"
                          Style="{StaticResource MaterialDesignActionToggleButton}"
                          ToolTip="MaterialDesignActionLightToggleButton"   Margin="5" MaxWidth="200" x:Name="CyclicalyLoadingOnlineData"  Checked="CyclicalyLoadingOnlineData_Checked" Unchecked="CyclicalyLoadingOnlineData_Unchecked"></ToggleButton>
                    <Label VerticalContentAlignment="Center" Visibility="{Binding ElementName=CyclicalyLoadingOnlineData,Path=IsChecked ,Converter={StaticResource BooleanToVisibilityConverter}}" Content="{x:Static p:strings.LoadDataCyclicaly}"></Label>
                    </StackPanel>
                    <vortex:RenderableContentControl Grid.Row="1" DataContext="{Binding _cuProcessDataDisplay}" PresentationType="ShadowDisplaySlim-ShadowDisplay"></vortex:RenderableContentControl>
                        
                </Grid>
            </TabItem>

            <TabItem Header="{x:Static p:strings.FullProcessData}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"></RowDefinition>
                        <RowDefinition></RowDefinition>

                    </Grid.RowDefinitions>
                    <Button Margin="10" MaxWidth="200" x:Name="LoadFullProcessDataButton" Content="{x:Static p:strings.LoadData}" Click="LoadFullProcessDataButton_Click"></Button>
                    <vortex:RenderableContentControl Grid.Row="1" DataContext="{Binding OnlineData}" PresentationType="ShadowDisplaySlim-ShadowDisplay"></vortex:RenderableContentControl>
                </Grid>
            </TabItem>
            <TabItem Header="{x:Static p:strings.StationTechnologyData}" DataContext="{Binding Component}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"></RowDefinition>
                        <RowDefinition></RowDefinition>

                    </Grid.RowDefinitions>
                    <Button Margin="10" MaxWidth="200" x:Name="LoadTechnologyDataButton" Content="{x:Static p:strings.LoadData}" Click="LoadTechnologyDataButton_Click"></Button>
                    <vortex:RenderableContentControl Grid.Row="1" DataContext="{Binding _cuTechnologicalDataDisplay}" PresentationType="ShadowDisplaySlim-ShadowDisplay"></vortex:RenderableContentControl>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
