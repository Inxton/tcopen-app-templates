<UserControl x:Class="x_template_xHmi.Wpf.Views.Data.BulkData.BulkDataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:x_template_xHmi.Wpf.Views.Data.ProcessSettings"
             xmlns:s="clr-namespace:x_template_xHmi.Wpf.Properties"   
             xmlns:vortexs="http://vortex.security.mts/xaml" 
             xmlns:vortex="http://vortex.mts/xaml" xmlns:bulkdata="clr-namespace:x_template_xHmi.Wpf.Views.Data.BulkData"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.DataContext>
        <bulkdata:BulkDataViewModel></bulkdata:BulkDataViewModel>
    </UserControl.DataContext>
    <Grid>
        <vortexs:PermissionBox Grid.Row="1" Permissions="process_settings_access" SecurityMode="Disabled">
            <vortex:BulkDataView DataContext="{Binding Data}"></vortex:BulkDataView>
        </vortexs:PermissionBox>
    </Grid>
</UserControl>
