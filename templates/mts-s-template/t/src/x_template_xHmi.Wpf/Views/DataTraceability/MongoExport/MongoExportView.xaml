<UserControl x:Class="x_template_xHmi.Wpf.Data.MongoExport.MongoExportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vortex="http://vortex.mts/xaml" xmlns:vortexs="http://vortex.security.mts/xaml"   
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" xmlns:mongoexport="clr-namespace:x_template_xHmi.Wpf.Data.MongoExport"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.DataContext>
        <mongoexport:MongoExportViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style TargetType="CheckBox" BasedOn="{StaticResource MaterialDesignAccentCheckBox}">
            <Setter Property="Margin" Value="5,0,5,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignHeadline2TextBlock}" x:Key="HeaderStyle">
            <Setter Property="Margin" Value="10"/>
            <Setter Property="FontSize" Value="40"/>
            <Setter Property="Foreground" Value="{StaticResource MtsBlack}"/>
            
        </Style>
    </UserControl.Resources>
    
    <Grid>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!--DATA TREE-->
        <TabControl>
            <TabItem Header="Data">
                <ScrollViewer PanningMode="Both" Background="Transparent">
                    <StackPanel>

                        <TextBlock Text="Data to export" Style="{StaticResource HeaderStyle}" Margin="10,10,10,30"/>

                        <TreeView ItemsSource="{Binding Model.Items}">
                            <TreeView.Resources>
                                <!-- Template for HeaderItem -->
                                <HierarchicalDataTemplate DataType="{x:Type mongoexport:HeaderItem}" ItemsSource="{Binding Items}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                                        <CheckBox IsChecked="{Binding Required,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" 
                                  IsThreeState="{Binding MidState,Mode=OneWay}"/>
                                    </StackPanel>

                                    <HierarchicalDataTemplate.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <CheckBox IsChecked="{Binding Included,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                <!--<TextBlock Text="{Binding Field}"/>-->
                                                <TextBlock Margin="10,0" Text="{Binding AttributeName}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </HierarchicalDataTemplate.ItemTemplate>
                                </HierarchicalDataTemplate>
                            </TreeView.Resources>
                        </TreeView>
                    </StackPanel>
                </ScrollViewer>

            </TabItem>
            <TabItem Header="Settings">
                <ScrollViewer PanningMode="Both" Background="Transparent">

                    <StackPanel>

                        <TextBlock Text="Inspectors data fields to export" Style="{StaticResource HeaderStyle}" Margin="10,10,10,30"/>

                        <TreeView ItemsSource="{Binding Model.InspectorsItems}">
                            <TreeView.Resources>
                                <!-- Template for HeaderItem -->
                                <HierarchicalDataTemplate DataType="{x:Type mongoexport:HeaderItem}" ItemsSource="{Binding Items}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                                        <CheckBox IsChecked="{Binding Required,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" 
                                  IsThreeState="{Binding MidState,Mode=OneWay}"/>
                                    </StackPanel>

                                    <HierarchicalDataTemplate.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <CheckBox IsChecked="{Binding Included,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                <!--<TextBlock Text="{Binding Field}"/>-->
                                                <TextBlock Margin="10,0" Text="{Binding AttributeName}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </HierarchicalDataTemplate.ItemTemplate>
                                </HierarchicalDataTemplate>
                            </TreeView.Resources>
                        </TreeView>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl> 
        
            
       

        
        
        
        
        <!--EXPORT NOW CARD-->
        <materialDesign:Card Grid.Row="0" Grid.Column="1"  Margin="50" Background="{StaticResource Surface}">
            <Grid>
                <Grid.Resources>
                    <Style TargetType="DatePicker" BasedOn="{StaticResource MaterialDesignOutlinedDatePicker}">
                        <Setter Property="Margin" Value="10"/>
                    </Style>
                    <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignTextBox}">
                        <Setter Property="Margin" Value="10,10,0,20"/>
                    </Style>
                </Grid.Resources>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Export Settings" Style="{StaticResource HeaderStyle}"/>

                <Grid Grid.Row="1" Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox materialDesign:HintAssist.HelperText="Output location" MinWidth="150" >
                        <TextBox.Text>
                            <Binding Path="OutputLocation"
                                     Mode="TwoWay"
                                     UpdateSourceTrigger="PropertyChanged"
                                     ValidatesOnNotifyDataErrors="True"
                                     ValidatesOnDataErrors="True"
                                     NotifyOnValidationError="True">
                                <Binding.ValidationRules>
                                    <mongoexport:PathValidationRule
                                                       ValidatesOnTargetUpdated="True" />
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>

                    </TextBox>

                    <vortexs:PermissionBox Grid.Column="1" Permissions="Administrator|can_export_data" SecurityMode="Disabled">
                        <Button  Content="Browse" Margin="10" Command="{Binding Browse}"/>
                    </vortexs:PermissionBox>
                    
                </Grid>




                <CheckBox Grid.Row="2" Margin="20,0" Content="Exact time" x:Name="timeEnable" IsChecked="{Binding ExactTime,Mode=TwoWay}"/>


                <DatePicker Grid.Row="3" MinWidth="150" MinHeight="50" Margin="20"
                        
                        materialDesign:HintAssist.HelperText="From"
                        materialDesign:HintAssist.Hint="Pick Date"
                            SelectedDate="{Binding SelectedFromDate, Mode=TwoWay}"/>

                <materialDesign:TimePicker Grid.Row="4" Margin="20"
                        Visibility="{Binding ExactTime, Converter={StaticResource BooleanToVisibilityConverter}}"
                        SelectedTime="{Binding SelectedFromDate, Mode=TwoWay}"
                        Is24Hours="True"
                        materialDesign:HintAssist.HelperText="From"
                        materialDesign:HintAssist.Hint="Pick Time"/>



                <DatePicker Grid.Row="5" MinWidth="150" MinHeight="50" Margin="20"
                        materialDesign:HintAssist.HelperText="To"
                        materialDesign:HintAssist.Hint="Pick Date"
                        SelectedDate="{Binding SelectedToDate, Mode=TwoWay}"/>

                <materialDesign:TimePicker Grid.Row="6" Margin="20"
                        Visibility="{Binding ExactTime, Converter={StaticResource BooleanToVisibilityConverter}}"
                        SelectedTime="{Binding SelectedToDate, Mode=TwoWay}"
                        Is24Hours="True"
                        materialDesign:HintAssist.HelperText="To"
                        materialDesign:HintAssist.Hint="Pick Time"/>

                <!--<Button Grid.Row="5" Content="Save Settings"  Margin="10" Command="{Binding Save}"/>-->
                <vortexs:PermissionBox Grid.Row="7" Permissions="Administrator|can_export_data" SecurityMode="Disabled">
                    <Button  Margin="10" Content="Export" Command="{Binding Export}"/>
                </vortexs:PermissionBox>
                
            </Grid>
        </materialDesign:Card>
    </Grid>

</UserControl>
