<UserControl x:Class="x_template_xHmi.Wpf.Views.Data.ProcessTraceability.ProcessTraceabilityView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:x_template_xHmi.Wpf.Views.Data.ProcessTraceability"
             xmlns:s="clr-namespace:x_template_xHmi.Wpf.Properties"
             xmlns:plc="clr-namespace:x_template_xPlc"
             xmlns:vortexs="http://vortex.security.mts/xaml" 
             xmlns:vortex="http://vortex.mts/xaml" xmlns:tcodata="clr-namespace:TcoData;assembly=TcOpen.Inxton.Data.Wpf" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" xmlns:wpf="clr-namespace:x_template_xPlc"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.DataContext>
        <local:ProcessTraceabilityViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>

        <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignTextBox}">
            <Setter Property="Margin" Value="15,0,0,0"/>
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignComboBox}">
            <Setter Property="Margin" Value="15,0,0,0"/>
        </Style>

        <plc:StationNameConverter x:Key="StationNameConverter"/>
        <plc:BoolToLocalizedStringConverter x:Key="BoolToLocalizedStringConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="{x:Static s:strings.FilterBy}" VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignSubtitle2TextBlock}"/>
                </TextBlock.Style>
            </TextBlock>

            <TextBlock Text="{x:Static s:strings.Result}" VerticalAlignment="Center" Margin="50,0,0,0"/>
            <ComboBox Width="100"
              ItemsSource="{Binding AvailableResults}"
              SelectedItem="{Binding SelectedResult}"
              DisplayMemberPath="Display" />

            <TextBlock Text="{x:Static s:strings.LastStation}" VerticalAlignment="Center" Margin="50,0,0,0"/>
            <ComboBox Width="80"
              ItemsSource="{Binding AvailableStations}"
              SelectedItem="{Binding SelectedStation}"
              DisplayMemberPath="Display" />
        </StackPanel>

        <vortexs:PermissionBox Grid.Row="1" Permissions="process_traceability_access" SecurityMode="Disabled">
            <tcodata:TcoDataExchangeDisplayView DataContext="{Binding ProcessData}" >
                <vortex:TcoDataExchangeDisplayView.DataListColumns>
                    <DataGridTextColumn Binding="{Binding EntityHeader.LastStation,Converter={StaticResource StationNameConverter}}" Header="{x:Static s:strings.LastStation}"/>
                    <DataGridTextColumn Binding="{Binding _Created, Converter={vortex:HumanizeDateConverter}}" Header="{x:Static s:strings.Created}"/>
                    <DataGridTextColumn Binding="{Binding _Modified, Converter={vortex:HumanizeDateConverter}}" Header="{x:Static s:strings.Modified}"/>
                    <!--<DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding EntityHeader.Results.Result}" Header="{x:Static s:strings.Result}"/>-->
                    <DataGridTemplateColumn Header="{x:Static s:strings.Result}" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Grid.Column="5" Margin="10,0" Orientation="Horizontal">
                                    <materialDesign:PackIcon HorizontalAlignment="Left" 
                                                 VerticalAlignment="Stretch"                                                  
                                                 Width="20"
                                                 Height="20"                                             
                                                 Kind="{Binding EntityHeader.Results.Result, Converter={wpf:DataStateToIconKindConverter}}" 
                                                 Background="Transparent"
                                                 Foreground="{Binding EntityHeader.Results.Result, Converter={wpf:OverallResultColorConverter}}"/>
                                    <TextBlock Margin="5,0" FontSize="12" TextWrapping="WrapWithOverflow" VerticalAlignment="Center" Text="{Binding EntityHeader.Results.Result, Converter={wpf:OverallResultDescriptionConverter}}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Width="*" Binding="{Binding EntityHeader.IsMaster, Converter={StaticResource BoolToLocalizedStringConverter}}" Header="Master"/>
                </vortex:TcoDataExchangeDisplayView.DataListColumns>
            </tcodata:TcoDataExchangeDisplayView>



        </vortexs:PermissionBox>
    </Grid>
</UserControl>
